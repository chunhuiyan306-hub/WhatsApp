# PostgreSQL（Vercel 用 Neon；本地开发也建议用 Neon 免费库或本地 Postgres）
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# 看板地址（本机 Worker 默认连本地；连线上时改为 https://xxx.vercel.app）
HUB_URL="http://localhost:3000"

# WhatsApp 扫描计划（本地时间）
SCAN_SCHEDULE="10:00,15:00"

# ── Vercel 生产环境（在 Vercel Dashboard 配置，勿提交 .env）──
# DATABASE_URL  — Neon Postgres 连接串（Storage 集成后自动注入）
# BLOB_READ_WRITE_TOKEN — Vercel Blob Token（上传 PDF 用）
