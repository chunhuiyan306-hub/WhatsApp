# ── 本地开发（Postgres，推荐 Neon dev branch）──
DATABASE_URL="postgresql://user:pass@host/neondb?sslmode=require"

# 看板地址
HUB_URL="http://localhost:3000"

# WhatsApp 扫描
SCAN_MAX_CHATS="30"
SCAN_MSG_LIMIT="10"
SCAN_SCHEDULE="10:00,15:00"

# 扫描机鉴权（生产必填；本地可留空则放行）
# INGEST_SECRET="local-dev-secret"

# ── Clerk 登录（Vercel Marketplace 自动注入）──
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ── Vercel 生产 ──
# DATABASE_URL / POSTGRES_URL — Neon Postgres
# BLOB_READ_WRITE_TOKEN — Vercel Blob
# INGEST_SECRET — 扫描机 Bearer 密钥（必填）

# 本地 SQLite 旧库迁移：npm run migrate:sqlite-to-pg
# 扫描机配置见 .env.scanner.example
