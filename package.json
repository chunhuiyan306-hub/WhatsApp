{
  "name": "whatsapp-customer-hub",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev --name init",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "seed": "tsx prisma/seed.ts",
    "seed:templates": "tsx scripts/seed-templates.ts",
    "auto": "node scripts/auto-worker.mjs",
    "auto:scan-once": "node scripts/wa-auto-scan.mjs",
    "pipeline:all": "node -e \"fetch('http://localhost:3000/api/automation',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({action:'pipeline-all'})}).then(r=>r.json()).then(console.log)\"",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "5.18.0",
    "@vercel/blob": "^0.23.4",
    "libphonenumber-js": "1.11.5",
    "next": "14.2.5",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "20.14.15",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.20",
    "playwright": "1.46.1",
    "postcss": "8.4.41",
    "prisma": "5.18.0",
    "tailwindcss": "3.4.10",
    "tsx": "4.16.5",
    "typescript": "5.5.4"
  }
}
